rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Analyses ────────────────────────────────────────────────
    match /analyses/{analysisId} {
      // Anyone can read a public analysis (Feature 6 — sharable link)
      allow read: if resource.data.isPublic == true;

      // Authenticated owner can read/write their own analyses
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.userId;

      // Allow create if authenticated (new analysis)
      allow create: if request.auth != null;
    }

    // ── Datasets ────────────────────────────────────────────────
    match /datasets/{datasetId} {
      // Only the uploader can read raw dataset rows
      allow read, write: if request.auth != null;
    }
  }
}
